from flask import Flask, request, jsonify
import fitz
import numpy as np

app = Flask(__name__)

ENGINE_NAME = "vLockedColorOnly_v12"
API_KEY = "ithrive_secure_2026_key"

TARGET_DPI = 400

Y_START = 1900
Y_END   = 4200

X_START = 1400
X_END   = 3250

DISEASE_NAMES = [
    "large_artery_stiffness",
    "peripheral_vessel",
    "blood_pressure_uncontrolled",
    "small_medium_artery_stiffness",
    "atherosclerosis",
    "ldl_cholesterol",
    "lv_hypertrophy",
    "metabolic_syndrome",
    "insulin_resistance",
    "beta_cell_function_decreased",
    "blood_glucose_uncontrolled",
    "tissue_inflammatory_process",
    "hypothyroidism",
    "hyperthyroidism",
    "hepatic_fibrosis",
    "chronic_hepatitis",
    "prostate_cancer",
    "respiratory_disorders",
    "kidney_function_disorders",
    "digestive_disorders",
    "major_depression",
    "adhd_children_learning",
    "cerebral_dopamine_decreased",
    "cerebral_serotonin_decreased",
]


def classify_color(rgb_row):

    rgb = rgb_row.astype(np.float32) / 255.0

    r = rgb[:, :, 0]
    g = rgb[:, :, 1]
    b = rgb[:, :, 2]

    cmax = np.maximum.reduce([r, g, b])
    cmin = np.minimum.reduce([r, g, b])
    delta = cmax - cmin

    sat = np.zeros_like(cmax)
    nonzero = cmax > 0
    sat[nonzero] = delta[nonzero] / cmax[nonzero]

    mask = sat > 0.30

    if np.sum(mask) < 5:
        return "None/Low"

    r_col = r[mask] * 255
    g_col = g[mask] * 255
    b_col = b[mask] * 255

    r_mean = np.mean(r_col)
    g_mean = np.mean(g_col)
    b_mean = np.mean(b_col)

    # Red dominance rule
    if r_mean > g_mean + 40 and r_mean > b_mean + 40:
        return "Severe"

    # Orange
    if r_mean > g_mean and g_mean > b_mean:
        return "Moderate"

    # Yellow
    if g_mean >= 140 and r_mean >= 140:
        return "Mild"

    return "None/Low"


@app.route("/v1/detect-disease-bars", methods=["POST"])
def detect():

    auth = request.headers.get("Authorization", "")
    if auth != f"Bearer {API_KEY}":
        return jsonify({"error": "Unauthorized"}), 401

    if "file" not in request.files:
        return jsonify({"error": "No file uploaded"}), 400

    file = request.files["file"]
    pdf_bytes = file.read()

    doc = fitz.open(stream=pdf_bytes, filetype="pdf")
    page = doc[1]

    zoom = TARGET_DPI / 72
    mat = fitz.Matrix(zoom, zoom)
    pix = page.get_pixmap(matrix=mat, alpha=False)

    img = np.frombuffer(pix.samples, dtype=np.uint8).reshape(
        pix.height, pix.width, 3
    )

    disease_block = img[Y_START:Y_END, X_START:X_END]

    total_height = disease_block.shape[0]

    # 🔧 FIXED: use float division to prevent cumulative drift
    row_height = total_height / 24.0

    results = {}

    for i, name in enumerate(DISEASE_NAMES):

        y1 = int(round(i * row_height))
        y2 = int(round((i + 1) * row_height))

        row = disease_block[y1:y2, :]

        # Center vertical band
        h = row.shape[0]
        cy1 = int(h * 0.35)
        cy2 = int(h * 0.65)
        row_center = row[cy1:cy2, :]

        # Horizontal band (15–85%)
        width = row_center.shape[1]
        x1 = int(width * 0.15)
        x2 = int(width * 0.85)

        sample = row_center[:, x1:x2]

        classification = classify_color(sample)
        results[name] = classification

    doc.close()

    return jsonify({
        "engine": ENGINE_NAME,
        "results": results
    })


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=10000)
